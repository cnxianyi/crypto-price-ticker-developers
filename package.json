{
  "name": "crypto-price-ticker-derivatives",
  "displayName": "Crypto Price Ticker Derivatives",
  "description": "Keep an eye on cryptocurrency derivatives prices as you code!",
  "keywords": [
    "bitcoin",
    "ethereum",
    "price",
    "crypto"
  ],
  "version": "1.2.1",
  "publisher": "cnxianyi",
  "repository": {
    "type": "git",
    "url": "https://github.com/cnxianyi/crypto-price-ticker-derivatives"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "configuration": {
      "properties": {
        "crypto-price-ticker-derivatives.interval": {
          "type": "number",
          "default": 60,
          "description": "The refresh interval in seconds."
        },
        "crypto-price-ticker-derivatives.onlyRefreshWhenFocused": {
          "type": "boolean",
          "default": false,
          "description": "Disable refreshing when the vscode window does not have focus."
        },
        "crypto-price-ticker-derivatives.higherColor": {
          "type": "string",
          "default": "lightgreen",
          "description": "The color that indicates the symbols is trading higher."
        },
        "crypto-price-ticker-derivatives.lowerColor": {
          "type": "string",
          "default": "coral",
          "description": "The color that indicates the symbols is trading lower."
        },
        "crypto-price-ticker-derivatives.tickers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "symbol": {
                "type": "string",
                "description": "The symbol to display."
              },
              "currency": {
                "type": "string",
                "default": "USDT",
                "description": "The currency to display the price in."
              },
              "exchange": {
                "type": "string",
                "description": "The exchange to get the price from."
              },
              "template": {
                "type": "string",
                "default": "{symbol} {price}",
                "description": "The template to use to display the ticker."
              },
              "provider": {
                "type": "string",
                "default": "Binance",
                "enum": [
                  "Binance"
                ],
                "description": "The provider to use to get the price."
              }
            },
            "required": [
              "symbol"
            ]
          },
          "default": [
            {
              "symbol": "BTC",
              "currency": "USDT",
              "provider": "Binance"
            },
            {
              "symbol": "ETH",
              "currency": "USDT",
              "provider": "Binance"
            }
          ],
          "description": "The array of ticker definitions to display in the status bar."
        },
        "crypto-price-ticker-derivatives.providers": {
          "type": "object",
          "properties": {
            "binance": {
              "type": "object",
              "properties": {
                "apiKey": {
                  "type": "string",
                  "default": "",
                  "description": "API key for Binance provider."
                },
                "secretKey": {
                  "type": "string",
                  "default": "",
                  "description": "Secret key for Binance provider."
                }
              },
              "default": {
                "apiKey": "",
                "secretKey": ""
              },
              "description": "Configuration for Binance provider."
            }
          },
          "default": {
            "binance": {
              "apiKey": "",
              "secretKey": ""
            }
          },
          "description": "API keys configuration for Binance provider."
        }
      }
    }
  },
  "scripts": {
    "build": "vsce package",
    "publish": "vsce publish",
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^10.12.21",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "typescript": "^4.5.5",
    "eslint": "^8.9.0"
  },
  "dependencies": {
    "got": "^11.8.3",
    "vsce": "^2.15.0"
  }
}
